PORT=4000
# Comma-separated list if you need multiple (e.g. testing on a LAN IP + localhost)
CLIENT_ORIGIN=http://localhost:3000

# Supabase (server-only service role -- chat-service reads/writes channels
# and messages directly)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Must match CHAT_AUTH_SECRET in web/.env.local exactly -- this is how
# chat-service verifies session tokens issued by the web app's
# /api/chat/enter route.
CHAT_AUTH_SECRET=

# Chat bot account: curated-content personas (FIDO, Felix, Luna). Create the
# account first via the admin panel's "Issue a VIP card" form, then paste
# its id here.
BOT_USER_PROFILE_ID=
