# Supabase (public site + private organization login area)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: bypasses RLS, used by API routes and the admin panel.
# Never expose this to the client / never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email: Email 1, Email 2, renewal, association checks)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@waspnest.org

# Admin panel (single flat login, no roles)
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Base URL used to build links in emails (verification, admin resolve, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Chat (must match CHAT_AUTH_SECRET in chat-service/.env exactly)
CHAT_AUTH_SECRET=
NEXT_PUBLIC_CHAT_SERVICE_URL=http://localhost:4000
